{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "RateLimiterPolicy": "auth-policy",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/product/{**catch-all}" }
      },
      "log-route": {
        "ClusterId": "log-cluster",
        "Match": { "Path": "/api/log/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": { "Address": "https://localhost:5121" }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product": { "Address": "https://localhost:5056" }
        }
      },
      "log-cluster": {
        "Destinations": {
          "log": { "Address": "https://localhost:5243" }
        }
      }
    }
  }
}
