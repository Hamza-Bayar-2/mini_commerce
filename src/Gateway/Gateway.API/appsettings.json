{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Key": "your-super-secret-key-with-at-least-32-characters",
    "Issuer": "AuthService"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "RateLimiterPolicy": "auth-policy",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/product/{**catch-all}" }
      },
      "log-route": {
        "ClusterId": "log-cluster",
        "Match": { "Path": "/api/log/{**catch-all}" }
      },
      "auth-swagger": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/swagger/auth/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/swagger/{**catch-all}" } ]
      },
      "product-swagger": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/swagger/product/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/swagger/{**catch-all}" } ]
      },
      "log-swagger": {
        "ClusterId": "log-cluster",
        "Match": { "Path": "/swagger/log/{**catch-all}" },
        "Transforms": [ { "PathPattern": "/swagger/{**catch-all}" } ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": { "Address": "https://localhost:5121" }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product": { "Address": "https://localhost:5056" }
        }
      },
      "log-cluster": {
        "Destinations": {
          "log": { "Address": "https://localhost:5243" }
        }
      }
    }
  }
}
