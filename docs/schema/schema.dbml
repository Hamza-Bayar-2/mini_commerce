/// ========> Ürün <========

Table products {
  id uuid [pk, default: `NEWID()`]
  status_id smallint [not null]
  name varchar(255) [not null]
  description text
  stock int [not null]
  created_at datetime2 [default: `GETUTCDATE()`]
  updated_at datetime2
  deleted_at datetime2
}
Ref: product_statuses.id < products.status_id [update: restrict, delete: restrict]

Table product_statuses {
  id smallint [pk]
  name varchar(30) [unique, not null]
  description text
}

Records product_statuses(id, name, description) {
  1, 'ACTIVE', 'Product is available for sale'
  2, 'INACTIVE', 'Product is not available'
  3, 'DRAFT', 'Product is being edited'
  4, 'BANNED', 'Product is prohibited'
  5, 'OUT_OF_STOCK', 'Product is currently out of stock'
}

