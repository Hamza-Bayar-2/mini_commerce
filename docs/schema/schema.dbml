/// ========> Kullanıcı <========

Table users {
  id uuid [pk, default: `NEWID()`]
  first_name varchar(50) [not null]
  last_name varchar(50) [not null]
  email varchar(255) [unique, not null, note: 'Giriş anahtarı']
  phone_number varchar(20) [unique]
  deleted_at datetime2 [note: 'Soft delete uygulanan kayıtların silinme anı']
  created_at datetime2 [default: `GETUTCDATE()`]
}

Table roles {
  id smallint [pk]
  name varchar(50) [not null, note: 'admin, customer, editor, warehouse_manager, seller']
}

// Junction table (Many-to-Many)
Table user_roles {
  user_id uuid [not null]
  role_id smallint [not null]
  
  Indexes {
    (user_id, role_id) [pk]
  }
}
Ref: users.id < user_roles.user_id [delete: cascade]
Ref: roles.id < user_roles.role_id [update: restrict, delete: restrict] 

Table user_credentials {
  user_id uuid [pk]
  password_hash text [not null]
  updated_at datetime2 [default: `GETUTCDATE()`]
}
Ref: users.id - user_credentials.user_id [delete: cascade]

Table user_refresh_tokens {
  id uuid [pk, default: `NEWID()`]
  user_id uuid [not null]
  token_hash text [not null]
  client_ip varchar(45)
  expires_at datetime2 [not null]
  is_revoked boolean [default: false, note: 'Güvenlik nedeniyle iptal edildi mi?']
  replaced_by uuid [note: 'Bu token yerine üretilen yeni token id']
  last_used_at datetime2 [default: `GETUTCDATE()`]
  created_at datetime2 [default: `GETUTCDATE()`]

  Indexes {
    token_hash [unique]
  }
}
Ref: users.id < user_refresh_tokens.user_id [delete: cascade]
Ref: user_refresh_tokens.id < user_refresh_tokens.replaced_by [delete: cascade]

